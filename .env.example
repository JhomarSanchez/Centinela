# Application
APP_ENV=development
API_KEY=change-me

# PostgreSQL (docker-compose.yml derives the backend's DATABASE_URL from these)
POSTGRES_DB=centinela
POSTGRES_USER=centinela
POSTGRES_PASSWORD=change-me

# Only needed when running the API outside Docker against a local PostgreSQL.
# DATABASE_URL=postgresql+psycopg://centinela:change-me@localhost:5432/centinela

# Health checks
DEFAULT_CHECK_INTERVAL_SECONDS=60
CHECK_TIMEOUT_SECONDS=5
# A successful response slower than this is reported as "degraded".
DEGRADED_LATENCY_MS=2000
# How often the scheduler looks for services due for a check.
SCHEDULER_TICK_SECONDS=10
# Checks older than this are deleted daily; 0 keeps history forever.
CHECK_RETENTION_DAYS=30

# Incidents (Phase 3): this many consecutive "down" checks open an incident.
INCIDENT_FAILURE_THRESHOLD=3

# Grafana (Phase 2) - credentials for the dashboard UI at http://localhost:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# Local AI (Phase 3). Set OLLAMA_ENABLED=false to run without the LLM:
# incidents still open and resolve, they just carry no AI summary.
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=120
