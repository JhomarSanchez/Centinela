{
  "title": "Centinela - Service Health",
  "uid": "centinela-service-health",
  "tags": ["centinela"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Current status",
      "description": "Latest health-check result per service.",
      "datasource": { "type": "prometheus", "uid": "centinela-prometheus" },
      "gridPos": { "h": 6, "w": 9, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "centinela_service_status",
          "legendFormat": "{{service_name}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "DEGRADED", "color": "orange", "index": 1 },
                "2": { "text": "UP", "color": "green", "index": 2 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "text", "value": null }]
          },
          "noValue": "No services registered yet"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Availability (dashboard time range)",
      "description": "Percentage of time each service was 'up' over the selected time range. Degraded time counts against availability.",
      "datasource": { "type": "prometheus", "uid": "centinela-prometheus" },
      "gridPos": { "h": 6, "w": 9, "x": 9, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(centinela_service_up[$__range]) * 100",
          "legendFormat": "{{service_name}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          },
          "noValue": "No data yet"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Open incidents",
      "description": "Services currently inside an unresolved incident (3+ consecutive down checks).",
      "datasource": { "type": "prometheus", "uid": "centinela-prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(centinela_incident_open)",
          "legendFormat": "open incidents",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Check latency",
      "description": "Latency of the most recent health check per service.",
      "datasource": { "type": "prometheus", "uid": "centinela-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "targets": [
        {
          "refId": "A",
          "expr": "centinela_check_latency_seconds",
          "legendFormat": "{{service_name}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true,
            "showPoints": "auto"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Checks by result",
      "description": "How many health checks finished up/degraded/down, across all services.",
      "datasource": { "type": "prometheus", "uid": "centinela-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (increase(centinela_checks_total[$__rate_interval]))",
          "legendFormat": "{{status}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "up" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "degraded" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "down" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      }
    }
  ]
}
